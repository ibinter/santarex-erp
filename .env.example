# ============================================================
# SANTAREX ERP - Variables d'environnement
# Copier ce fichier : cp .env.example .env
# NE PAS commiter le fichier .env dans git
# ============================================================

# App
NODE_ENV=development
APP_NAME=SANTAREX ERP
APP_VERSION=1.0.0

# Backend
BACKEND_PORT=3001
JWT_SECRET=change_me_in_production
JWT_REFRESH_SECRET=change_me_refresh_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Database PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=santarex_db
DB_USER=santarex
DB_PASSWORD=santarex_secure_password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Elasticsearch
ELASTICSEARCH_NODE=http://localhost:9200

# MinIO / Storage
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=santarex-files

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_APP_NAME=SANTAREX ERP

# SMS (Twilio / Orange)
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Email
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=

# Multi-tenant
DEFAULT_TENANT_SCHEMA=public
