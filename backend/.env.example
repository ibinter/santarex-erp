# ============================================================
# SANTAREX ERP — Variables d'environnement (exemple)
# Copier vers .env (dev) ou .env.prod (production)
# NE JAMAIS commiter les valeurs réelles
# ============================================================

# Base de données PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=santarex
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=santarex_db

# JWT
JWT_SECRET=CHANGE_ME_64_CHAR_RANDOM_STRING
JWT_REFRESH_SECRET=CHANGE_ME_64_CHAR_RANDOM_STRING_DIFFERENT
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Application
NODE_ENV=production
BACKEND_PORT=3001
FRONTEND_URL=https://santarex.ibigsoft.com

# SMTP — Email transactionnel
# Option 1 : Gmail (activer "Mot de passe d'application" dans les paramètres Google)
# Option 2 : Brevo / Mailgun / SendGrid (recommandé pour la production)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=votre-email@gmail.com
SMTP_PASS=votre-mot-de-passe-application
SMTP_FROM=contact@ibigsoft.com

# Frontend (Next.js)
NEXT_PUBLIC_API_URL=https://santarex.ibigsoft.com/api/v1

# URL publique du backend (pour les webhooks paiement)
APP_URL=https://santarex.ibigsoft.com

# IA — Assistant SARA (au moins un provider requis)
# Groq — gratuit, rapide, recommandé : https://console.groq.com/keys
GROQ_API_KEY=CHANGE_ME_GROQ_API_KEY
# Anthropic Claude — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=CHANGE_ME_ANTHROPIC_API_KEY
# OpenAI GPT — https://platform.openai.com/api-keys
OPENAI_API_KEY=CHANGE_ME_OPENAI_API_KEY

# Moneroo — agrégateur de paiement (CinetPay, Orange Money, Wave, MTN MoMo, Visa/MC…)
# Créer un compte sur : https://moneroo.io
# Dashboard : https://app.moneroo.io/settings/api
MONEROO_SECRET_KEY=CHANGE_ME_MONEROO_SECRET_KEY
# Secret pour vérifier les signatures des webhooks Moneroo
MONEROO_WEBHOOK_SECRET=CHANGE_ME_MONEROO_WEBHOOK_SECRET
