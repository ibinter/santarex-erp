# ============================================================
# SANTAREX ERP — Variables d'environnement (exemple)
# Copier vers .env (dev) ou .env.prod (production)
# NE JAMAIS commiter les valeurs réelles
# ============================================================

# Base de données PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=santarex
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=santarex_db

# JWT
JWT_SECRET=CHANGE_ME_64_CHAR_RANDOM_STRING
JWT_REFRESH_SECRET=CHANGE_ME_64_CHAR_RANDOM_STRING_DIFFERENT
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Application
NODE_ENV=production
BACKEND_PORT=3001
FRONTEND_URL=https://santarex.ibigsoft.com

# SMTP — Email transactionnel
# Option 1 : Gmail (activer "Mot de passe d'application" dans les paramètres Google)
# Option 2 : Brevo / Mailgun / SendGrid (recommandé pour la production)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=votre-email@gmail.com
SMTP_PASS=votre-mot-de-passe-application
SMTP_FROM=contact@ibigsoft.com

# Frontend (Next.js)
NEXT_PUBLIC_API_URL=https://santarex.ibigsoft.com/api/v1

# URL publique du backend (pour les webhooks paiement)
APP_URL=https://santarex.ibigsoft.com

# CinetPay — https://cinetpay.com
# Obtenir les clés sur : https://dashboard.cinetpay.com/
CINETPAY_API_KEY=CHANGE_ME_CINETPAY_API_KEY
CINETPAY_SITE_ID=CHANGE_ME_CINETPAY_SITE_ID

# Orange Money CI — https://developer.orange.com/
# Nécessite un compte marchand Orange Business CI
ORANGE_MONEY_MERCHANT_KEY=CHANGE_ME_ORANGE_MONEY_MERCHANT_KEY
ORANGE_MONEY_AUTH_HEADER=CHANGE_ME_ORANGE_MONEY_BASIC_AUTH_BASE64
