<div class="warning-box">
  <p><strong>Détails de la connexion</strong><br/>
  Date et heure : <strong>{{dateConnexion}}</strong><br/>
  Adresse IP : <strong>{{adresseIp}}</strong><br/>
  Navigateur : <strong>{{navigateur}}</strong><br/>
  Établissement : <strong>{{tenantSlug}}</strong>
