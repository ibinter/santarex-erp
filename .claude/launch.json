{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Frontend (Next.js)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--", "-p", "3003"],
      "port": 3003,
      "autoPort": false
    },
    {
      "name": "Backend (NestJS)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "start:dev"],
      "port": 3002,
      "autoPort": false
    },
    {
      "name": "Full Stack (Frontend + Backend)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3003,
      "autoPort": false
    }
  ]
}
